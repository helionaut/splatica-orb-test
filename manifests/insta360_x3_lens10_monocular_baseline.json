{
  "baseline": {
    "name": "orbslam3-official-v1.0-release",
    "repo_url": "https://github.com/UZ-SLAMLab/ORB_SLAM3",
    "commit": "0df83dde1c85c7ab91a0d47de7a29685d046f637",
    "checkout_path": "third_party/orbslam3/upstream",
    "executable_path": "Examples/Monocular/mono_tum_vi",
    "vocabulary_path": "Vocabulary/ORBvoc.txt"
  },
  "sequence": {
    "name": "insta360-x3-lens10-monocular-baseline",
    "camera_label": "insta360_x3_lens10",
    "calibration_path": "datasets/user/insta360_x3_lens10/monocular_calibration.json",
    "frame_index_path": "datasets/user/insta360_x3_lens10/frame_index.csv"
  },
  "outputs": {
    "settings_path": "build/insta360_x3_lens10/monocular/TUM-VI-insta360-x3-lens10.yaml",
    "image_dir": "build/insta360_x3_lens10/monocular/images",
    "timestamps_path": "build/insta360_x3_lens10/monocular/timestamps.txt",
    "trajectory_stem": "build/insta360_x3_lens10/monocular/trajectory/insta360_x3_lens10",
    "log_path": "logs/out/insta360_x3_lens10_monocular.log",
    "report_path": "reports/out/insta360_x3_lens10_monocular.md"
  },
  "launch": {
    "mode": "monocular_tum_vi",
    "script": "scripts/run_orbslam3_sequence.sh"
  },
  "notes": "Single-lens Insta360 X3 Lens 10 baseline that follows the upstream ORB-SLAM3 monocular fisheye TUM-VI path without IMU. Preprocessing must provide a frame_index.csv with timestamp_ns,source_path rows and PNG source frames."
}
